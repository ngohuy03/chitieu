## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.
# User-specific files
*.rsuser
*.suo
*.user
*.userndoc
*.vspscc
*.vsscc
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Uncomment if you have tasks that create to-do list files in the project directory
#*.tasks

# MSTest test Results
[T]est[R]esult*/
[B]uild[L]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Mono Game Portability Analyzer
PortabilityReport.html

# Spark
Nyx/

# Entity Framework 3-5 registries
   # Removed to avoid ignoring database registry files

# Client-side libraries
node_modules/

# Server-side secrets (contains database connection string)
appsettings.json
appsettings.Development.json
appsettings.Production.json

# Cloud Service publish settings
*.PublishSettings

# Rider
.idea/

# VS Code
.vscode/
